{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run C Program",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "gcc ${file} -o ${fileDirname}\\main; if ($?) { & \"${fileDirname}\\main\" }"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}